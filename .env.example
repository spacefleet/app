ADDR=:8080
ENV=development

# Clerk auth
CLERK_PUBLISHABLE_KEY=INSERT_YOUR_PUBLISHABLE_KEY
CLERK_SECRET_KEY=INSERT_YOUR_SECRET_KEY

# Postgres (matches docker-compose defaults)
POSTGRES_USER=spacefleet
POSTGRES_PASSWORD=spacefleet
POSTGRES_DB=spacefleet
DATABASE_URL=postgres://spacefleet:spacefleet@localhost:5432/spacefleet?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# GitHub App credentials. Each Spacefleet install (hosted, self-host) registers
# its own App on GitHub; we ship the code parameterized over these. Leave
# unset to disable the GitHub flows entirely.
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_WEBHOOK_SECRET=
# Provide either the PEM contents directly (multi-line var) or a path to it
# on disk. Path wins if both are set.
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_PATH=

# AWS cloud-account onboarding. Both must be set to enable the flow.
# AWS_PLATFORM_ACCOUNT_ID is the 12-digit account ID Spacefleet runs in —
# the principal that customer IAM trust policies will allow AssumeRole
# from. AWS_CFN_TEMPLATE_URL points at a publicly fetchable
# CloudFormation template (see infra/aws/onboarding-template.yaml for a
# starting point — host it on S3+CloudFront or any HTTPS CDN).
#
# AWS credentials themselves come from the standard AWS SDK chain
# (AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY env vars, ~/.aws/credentials,
# or the IAM role on whatever runs Spacefleet). The verification probe
# uses those creds to AssumeRole into the customer's role.
AWS_PLATFORM_ACCOUNT_ID=
AWS_CFN_TEMPLATE_URL=https://raw.githubusercontent.com/spacefleet/app/refs/heads/main/infra/aws/onboarding-template.yaml
