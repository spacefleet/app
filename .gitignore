# --- OS / editor ---
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# --- secrets / local env ---
.env
.env.*.local
*.local

# --- Go ---
bin/
tmp/
*.log
*.test
*.out
coverage.out
coverage.html

# --- Claude Code ---
# Keep .claude/settings.json (shared), agents/, commands/, hooks/, skills/ — ignore per-user only.
.claude/settings.local.json
.claude/**/*.local.json
CLAUDE.custom.md

# --- Node / frontend ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache
.cache/
.parcel-cache/

# --- TypeScript / Vite ---
*.tsbuildinfo

# --- UI build artifacts (regenerated by `make ui-build`) ---
# Keep .gitkeep so go:embed has something to match on fresh clones.
ui/dist/*
!ui/dist/.gitkeep
